---
const home = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <title>404 · Grok Build Architecture</title>
    <style>
      :root { color-scheme: dark; font-family: Inter, "PingFang SC", "Microsoft YaHei", sans-serif; background:#090b0e; color:#f5f7f9; }
      body { margin:0; min-height:100vh; display:grid; place-items:center; background:radial-gradient(circle at 70% 20%,#15324b 0,transparent 34%),#090b0e; }
      main { width:min(720px,calc(100% - 48px)); border-top:1px solid #2e9fff; padding-top:24px; }
      small { color:#2e9fff; letter-spacing:.18em; }
      h1 { font-size:clamp(4rem,18vw,10rem); line-height:.8; margin:2rem 0; letter-spacing:-.08em; }
      p { color:#aeb8c2; max-width:40rem; font-size:1.1rem; }
      a { color:#fff; display:inline-block; margin-top:2rem; text-decoration:none; border-bottom:1px solid #2e9fff; padding-bottom:.35rem; }
      a:focus-visible { outline:3px solid #2e9fff; outline-offset:6px; }
    </style>
  </head>
  <body><main><small>ROUTE NOT FOUND / 404</small><h1>信号中断</h1><p>这个地址不在当前源码基线的文档路由中。返回阅读首页，重新进入架构链路。</p><a href={home}>返回首页 →</a></main></body>
</html>

